{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/images/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "redirects": [
    { "source": "/", "destination": "/fr", "permanent": false },
    { "source": "/ro/bine-ai-venit", "destination": "/ro", "permanent": true },
    { "source": "/ro/contact-ro", "destination": "/ro/contact", "permanent": true },
    { "source": "/en/welcome", "destination": "/en", "permanent": true },
    { "source": "/en/services-en", "destination": "/en/services", "permanent": true },
    { "source": "/en/contact-en", "destination": "/en/contact", "permanent": true },
    { "source": "/services", "destination": "/fr/services", "permanent": false },
    { "source": "/monhistoire", "destination": "/fr/mon-histoire", "permanent": true },
    { "source": "/contact-fr", "destination": "/fr/contact", "permanent": true },
    { "source": "/blog/:slug*", "destination": "/fr/blog/:slug*", "permanent": false },
    { "source": "/deni-de-responsabilite-et-droits-dauteur", "destination": "/fr/disclaimer", "permanent": true },
    { "source": "/politique-de-confidentialite", "destination": "/fr/privacy", "permanent": true }
  ]
}
